name: test

on:
  workflow_dispatch:
    inputs:
      ubi_version:
        description: "UBI Version"
        required: true
        default: "9"

      tomcat_major:
        description: "Tomcat Major Version"
        required: true
        default: "9"

      java_version:
        description: "Java Version"
        required: true
        default: "17"

      image_name:
        description: "Docker Image Name"
        required: true
        default: "ubi-tomcat"

jobs:

  start:
    runs-on: ubuntu-latest
    steps:
      - name: Start Workflow
        run: echo "Workflow Started"

  checkout-source:
    runs-on: ubuntu-latest
    needs: start

    steps:
      - name: Checkout Source
        uses: actions/checkout@v4

  detect-tomcat:
    runs-on: ubuntu-latest
    needs: checkout-source

    outputs:
      tomcat_version: ${{ steps.detect.outputs.version }}

    steps:
      - name: Detect Latest Tomcat Version
        id: detect
        run: |
          MAJOR=${{ github.event.inputs.tomcat_major }}

          VERSION=$(curl -s https://downloads.apache.org/tomcat/tomcat-$MAJOR/ \
            | grep -oP 'v\K[0-9]+\.[0-9]+\.[0-9]+' \
            | sort -V \
            | tail -1)

          echo "version=$VERSION" >> $GITHUB_OUTPUT

  set-java:
    runs-on: ubuntu-latest
    needs: detect-tomcat

    steps:
      - name: Set Java Version
        run: |
          echo "Java Version: ${{ github.event.inputs.java_version }}"

  docker-login:
    runs-on: ubuntu-latest
    needs: set-java

    steps:
      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

  build-image:
    runs-on: ubuntu-latest
    needs: docker-login

    steps:
      - name: Checkout Source
        uses: actions/checkout@v4

      - name: Build Docker Image
        run: |
          docker build \
            --progress=plain \
            --no-cache \
            --build-arg UBI_VERSION=${{ github.event.inputs.ubi_version }} \
            --build-arg TOMCAT_MAJOR=${{ github.event.inputs.tomcat_major }} \
            --build-arg TOMCAT_VERSION=${{ needs.detect-tomcat.outputs.tomcat_version }} \
            --build-arg JAVA_VERSION=${{ github.event.inputs.java_version }} \
            -t ${{ secrets.DOCKER_USERNAME }}/${{ github.event.inputs.image_name }}:latest .

  push-image:
    runs-on: ubuntu-latest
    needs: build-image

    steps:
      - name: Push Docker Image
        run: |
          docker push \
            ${{ secrets.DOCKER_USERNAME }}/${{ github.event.inputs.image_name }}:latest

  complete:
    runs-on: ubuntu-latest
    needs: push-image

    steps:
      - name: Complete Workflow
        run: echo "Docker Image Successfully Published"
